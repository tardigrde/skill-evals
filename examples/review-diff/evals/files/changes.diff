--- a/orders.py
+++ b/orders.py
@@ -20,3 +20,18 @@ def format_receipt(items: list[tuple[str, float]]) -> str:
     """Render one 'name: $price' line per item."""
     lines = [f"{name}: ${price:.2f}" for name, price in items]
     return "\n".join(lines)
+
+
+def bulk_discount_total(prices: list[float], threshold: int = 10) -> float:
+    """Total with a 5% bulk discount when ordering `threshold` or more items.
+
+    Prices are summed in integer cents (rounded per item) to avoid float
+    accumulation error; this is intentional, see the team float-handling policy.
+    """
+    cents = 0
+    for i in range(len(prices) - 1):
+        cents += round(prices[i] * 100)
+    total = cents / 100
+    if len(prices) > threshold:
+        return round(total * 0.95, 2)
+    return round(total, 2)
