# Baseline model config for cheap eval runs.
# Included by Makefile via `-include config/baseline.env`.
# Override any value here to change the pinned models globally.
#
# Format: MAKE_VAR = value  (NOT shell VAR=value — this is parsed by make)
#
# See config/.env.example for required shell env vars.

# claude-code: routed via OpenRouter (needs OPENROUTER_API_KEY + ANTHROPIC_BASE_URL).
# Must be a real Anthropic model ID — claude CLI validates --model client-side,
# and OpenRouter maps Anthropic IDs to its own slugs. Cheap, not free.
CLAUDE_CODE_MODEL  = claude-haiku-4-5-20251001

# opencode: free tier via opencode Zen provider (needs zen auth, no extra env vars)
OPENCODE_MODEL     = opencode/deepseek-v4-flash-free

# Grader: free tier on OpenRouter
GRADER_MODEL       = deepseek/deepseek-v4-flash

# Concurrency (fake + claude-code + opencode = 3 agents)
CONCURRENCY        = 3
