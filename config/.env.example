# Shell env vars required for cheap-eval.
# Copy to .env (auto-loaded by skill-eval via python-dotenv) or export in shell.
# Never commit .env — it's in .gitignore.

OPENROUTER_API_KEY=sk-or-...

# ── claude-code harness (routes to OpenRouter) ───────────────────────────────
# OpenRouter speaks Anthropic API at /api (no /v1 suffix — claude appends /v1/messages).
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_AUTH_TOKEN=${OPENROUTER_API_KEY}
ANTHROPIC_API_KEY=    # must be blank — prevents clash with direct Anthropic auth

# ── opencode harness (routes via Zen provider) ───────────────────────────────
# No extra env vars needed — opencode uses its own zen auth from ~/.local/share/opencode/auth.json.
# Run `opencode` TUI once, /connect → OpenCode Zen, to set it up.

# ── grader (LLMGrader uses OPENROUTER_API_KEY directly) ─────────────────────
# Nothing extra needed — OPENROUTER_API_KEY above is enough.

# ── codex harness (excluded from cheap-eval) ─────────────────────────────────
# Codex requires ~/.codex/config.toml for provider setup, not just env vars.
# Example config.toml for OpenRouter:
#
#   model_provider = "openrouter"
#   model = "deepseek/deepseek-v4-flash:free"
#
#   [model_providers.openrouter]
#   name = "openrouter"
#   base_url = "https://openrouter.ai/api/v1"
#   env_key = "OPENROUTER_API_KEY"
